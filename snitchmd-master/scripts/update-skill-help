#!/usr/bin/env python3
"""Replace the embedded `snitchmd --help` block in SKILL.md with text from stdin.

Pipe the live help output in:
    docker run --rm snitchmd:local --help | scripts/update-skill-help
"""
from __future__ import annotations

import re
import sys
from pathlib import Path

SKILL_PATH = Path(__file__).resolve().parent.parent / "skills" / "snitchmd" / "SKILL.md"
BEGIN = "<!-- BEGIN: snitchmd --help -->"
END = "<!-- END: snitchmd --help -->"


def main() -> int:
    help_text = sys.stdin.read().strip()
    if not help_text:
        print("update-skill-help: empty stdin — pipe `snitchmd --help` in.", file=sys.stderr)
        return 1

    if not SKILL_PATH.is_file():
        print(f"update-skill-help: {SKILL_PATH} not found", file=sys.stderr)
        return 1

    content = SKILL_PATH.read_text(encoding="utf-8")
    pattern = re.compile(rf"{re.escape(BEGIN)}.*?{re.escape(END)}", re.DOTALL)
    if not pattern.search(content):
        print(f"update-skill-help: markers {BEGIN!r}/{END!r} not found in {SKILL_PATH}", file=sys.stderr)
        return 1

    new_block = f"{BEGIN}\n```text\n{help_text}\n```\n{END}"
    # Use a callable replacement so re.sub doesn't interpret backslash
    # sequences (\n, \g<…>, …) inside `help_text` as regex escapes.
    new_content = pattern.sub(lambda _: new_block, content, count=1)

    if new_content == content:
        print("update-skill-help: already in sync.")
        return 0

    SKILL_PATH.write_text(new_content, encoding="utf-8")
    print(f"update-skill-help: updated {SKILL_PATH}.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
