#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: scripts/bump-version VERSION" >&2
  exit 1
fi

version="$1"
if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "Version must be semver without v prefix, e.g. 0.1.3" >&2
  exit 1
fi

perl -0pi -e 's/version := "[^"]+"/version := "'"$version"'"/' Justfile

echo "Bumped snitchmd to $version"
