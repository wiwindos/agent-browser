#!/bin/sh

if ! command -v docker >/dev/null 2>&1; then
  echo "snitchmd: Docker is not installed or not in PATH." >&2
  exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo "snitchmd: Docker is installed, but the Docker daemon is not running or is not accessible." >&2
  exit 1
fi

if [ "$#" -eq 0 ] && [ ! -t 0 ]; then
  if IFS= read -r snitchmd_url && [ -n "$snitchmd_url" ]; then
    set -- "$snitchmd_url"
  fi
fi

tty_flag=
if [ -t 0 ]; then
  tty_flag="-t"
fi

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/snitchmd"
mkdir -p "$cache_dir" || exit 1

exec docker run --platform linux/amd64 --rm -i $tty_flag \
  -v "$cache_dir:/cache" \
  syabro/snitchmd "$@"
